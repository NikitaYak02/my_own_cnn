{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2022-base",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "ENABLE_CUDNN": "ON"
      }
    },
    {
      "name": "linux-gcc-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-linux-base",
      "cacheVariables": {
        "ENABLE_CUDNN": "ON",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_CUDA_HOST_COMPILER": "g++"
      },
      "environment": {
        "CC": "gcc",
        "CXX": "g++"
      }
    },
    {
      "name": "sm75",
      "displayName": "CUDA sm75 (Turing)",
      "inherits": "vs2022-base",
      "binaryDir": "${sourceDir}/build-sm75",
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "75"
      }
    },
    {
      "name": "auto",
      "displayName": "CUDA native (auto-detect current GPU)",
      "inherits": "vs2022-base",
      "binaryDir": "${sourceDir}/build-auto",
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "native"
      }
    },
    {
      "name": "sm86",
      "displayName": "CUDA sm86 (Ampere 3090/A6000)",
      "inherits": "vs2022-base",
      "binaryDir": "${sourceDir}/build-sm86",
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "86"
      }
    },
    {
      "name": "sm89",
      "displayName": "CUDA sm89 (Ada 4090)",
      "inherits": "vs2022-base",
      "binaryDir": "${sourceDir}/build-sm89",
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "89"
      }
    },
    {
      "name": "linux-sm75-gcc",
      "displayName": "Linux GCC + CUDA sm75",
      "inherits": "linux-gcc-base",
      "binaryDir": "${sourceDir}/build-linux-sm75-gcc",
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "75"
      }
    },
    {
      "name": "linux-auto-gcc",
      "displayName": "Linux GCC + CUDA native (auto-detect current GPU)",
      "inherits": "linux-gcc-base",
      "binaryDir": "${sourceDir}/build-linux-auto-gcc",
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "native"
      }
    },
    {
      "name": "linux-sm86-gcc",
      "displayName": "Linux GCC + CUDA sm86 (Ampere 3090/A6000)",
      "inherits": "linux-gcc-base",
      "binaryDir": "${sourceDir}/build-linux-sm86-gcc",
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "86"
      }
    },
    {
      "name": "linux-sm89-gcc",
      "displayName": "Linux GCC + CUDA sm89 (Ada 4090)",
      "inherits": "linux-gcc-base",
      "binaryDir": "${sourceDir}/build-linux-sm89-gcc",
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "89"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "sm75-release",
      "configurePreset": "sm75",
      "configuration": "Release"
    },
    {
      "name": "auto-release",
      "configurePreset": "auto",
      "configuration": "Release"
    },
    {
      "name": "sm86-release",
      "configurePreset": "sm86",
      "configuration": "Release"
    },
    {
      "name": "sm89-release",
      "configurePreset": "sm89",
      "configuration": "Release"
    },
    {
      "name": "linux-sm75-gcc-release",
      "configurePreset": "linux-sm75-gcc"
    },
    {
      "name": "linux-auto-gcc-release",
      "configurePreset": "linux-auto-gcc"
    },
    {
      "name": "linux-sm86-gcc-release",
      "configurePreset": "linux-sm86-gcc"
    },
    {
      "name": "linux-sm89-gcc-release",
      "configurePreset": "linux-sm89-gcc"
    }
  ]
}
